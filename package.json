{
  "name": "secret-market",
  "version": "0.1.0",
  "private": true,
  "description": "Secret Market MVP prototype with static frontend and lightweight Node API.",
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind.css -o ./assets/tailwind.css --minify",
    "build:pages": "node scripts/build-pages.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "start": "node backend/server.js",
    "start:api": "node backend/server.js",
    "start:pages": "node scripts/serve-pages.js",
    "start:web": "node server.js",
    "verify": "node verify-env.js && node verify-passwords.js && node verify-telegram-notifier.js && node verify-public-config.js && node verify-backend.js && node verify-api-client.js && node verify-live-sync.js && node verify-live-ui.js && node verify-pages.js && node verify-github-pages-assets.js && node verify.js && node scripts/build-pages.js && node verify-dist.js && node verify-404.js",
    "verify:404": "node verify-404.js",
    "verify:backend": "node verify-backend.js",
    "verify:env": "node verify-env.js",
    "verify:telegram": "node verify-telegram-notifier.js",
    "verify:github-pages-assets": "node verify-github-pages-assets.js",
    "verify:api-client": "node verify-api-client.js",
    "verify:build": "node scripts/build-pages.js",
    "verify:dist": "node verify-dist.js",
    "verify:live-ui": "node verify-live-ui.js",
    "verify:live-sync": "node verify-live-sync.js",
    "verify:pages": "node verify-pages.js",
    "verify:passwords": "node verify-passwords.js",
    "verify:public-config": "node verify-public-config.js",
    "verify:routes": "node verify.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7"
  }
}
