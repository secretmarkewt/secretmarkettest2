# Secret Market API runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=4174

# Persist the MVP JSON database outside the repository on public hosts.
SECMARKET_DB_FILE=/data/secmarket-db.json

# Required for production: at least 32 chars, used to encrypt auto-delivery secrets.
SECMARKET_SECRET_KEY=change-me-to-a-long-random-secret-key-32-plus

# File storage for ticket/dispute/order evidence on the backend host.
SECMARKET_EVIDENCE_DIR=/data/evidence

# JSON-store safety backups. Keep this on persistent storage.
SECMARKET_BACKUP_DIR=/data/backups

# Comma-separated browser origins allowed to call the API.
SECMARKET_ALLOWED_ORIGINS=https://penisxxxl.github.io,http://127.0.0.1:4173

# Keep this disabled on public deployments.
SECMARKET_ALLOW_RESET=false

# Basic per-IP API limit.
SECMARKET_RATE_LIMIT_MAX=240
SECMARKET_RATE_LIMIT_WINDOW_MS=60000

# Production payment watcher workers. Each endpoint should return JSON with
# txHash/transactionId, confirmations and optional status.
SECMARKET_TRC20_WATCHER_URL=
SECMARKET_TON_WATCHER_URL=
SECMARKET_BEP20_WATCHER_URL=
SECMARKET_PAYMENT_WATCHER_API_KEY=
SECMARKET_PAYMENT_WATCHER_TIMEOUT_MS=8000

# Telegram registration notifications. Keep the bot token secret.
SECMARKET_TELEGRAM_BOT_TOKEN=
SECMARKET_TELEGRAM_REGISTRATION_CHAT_ID=7391093210

# Public frontend config for GitHub Pages. Supabase anon key is public by design;
# never put service_role keys into frontend config.
SECMARKET_PUBLIC_API_URL=
SECMARKET_PUBLIC_SUPABASE_URL=
SECMARKET_PUBLIC_SUPABASE_ANON_KEY=
